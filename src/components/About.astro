            class="w-full h-48 object-cover rounded-lg mb-4"
          />
          <h3 class="text-xl font-semibold text-white mb-2">Mt. Bachelor</h3>
          <p class="text-slate-300">
            Premier skiing and snowboarding destination
          </p>
        </div>

        <div
          class="bg-slate-700 p-6 rounded-lg shadow-md hover:shadow-lg transition-shadow"
        >
          <img
            src="https://images.unsplash.com/photo-1492041435129-3d91e5b0d79f?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixid=M3w3Nzg4Nzd8MHwxfHNlYXJjaHwxfHxicm9rZW4lMjB0b3AlMjB0aHJlZSUyMHNpc3RlcnMlMjBtb3VudGFpbnxlbnwxfHx8fDE3NzA0MDEyMDF8MA&ixlib=rb-4.1.0&q=80&w=1080"
