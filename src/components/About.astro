      </div>
    </div>

    <!-- Based in Bend Section -->
    <div>
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
          Based in Bend, Oregon
        </h2>
        <p class="text-xl text-slate-300 max-w-3xl mx-auto">
          While we serve businesses nationwide, our heart is in Central Oregon.
          From the slopes of Mt. Bachelor to the trails of Smith Rock, this is
          where we call home.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div
          class="bg-slate-700 p-6 rounded-lg shadow-md hover:shadow-lg transition-shadow"
        >
          <img
            src="https://images.unsplash.com/photo-1521325634587-fbd095847273?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixid=M3w3Nzg4Nzd8MHwxfHNlYXJjaHwxfHxTbWl0aCUyMFJvY2slMjBoaWtpbmclMjBPcmVnb258ZW58MXx8fHwxNzcwNDAxMjAxfDA&ixlib=rb-4.1.0&q=80&w=1080"
            alt="Smith Rock State Park"
            class="w-full h-48 object-cover rounded-lg mb-4"
          />
          <h3 class="text-xl font-semibold text-white mb-2">
            Smith Rock State Park
          </h3>
          <p class="text-slate-300">
            World-class rock climbing and hiking trails
          </p>
        </div>

        <div
          class="bg-slate-700 p-6 rounded-lg shadow-md hover:shadow-lg transition-shadow"
        >
          <img
            src="https://images.unsplash.com/photo-1642045544498-ba9e7ffc1364?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixid=M3w3Nzg4Nzd8MHwxfHNlYXJjaHwxfHxza2lpbmclMjBwb3dkZXIlMjBzbm93fGVufDF8fHx8MTc3MDQwMTIwMHww&ixlib=rb-4.1.0&q=80&w=1080"
